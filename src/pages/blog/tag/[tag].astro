---
import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import ReadingTime from "../../../components/ReadingTime.astro";
import Layout from "../../../layouts/Layout.astro";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog");

  // Collect all unique tags
  const tags = new Set<string>();
  posts.forEach((post) => {
    if (post.data.tags) {
      post.data.tags.forEach((tag) => tags.add(tag));
    }
  });

  // Generate a path for each tag
  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}) satisfies GetStaticPaths;

const allPosts = await getCollection("blog");
const { tag } = Astro.params;

// Filter posts by the selected tag
const filteredPosts = allPosts
  .filter((post) => post.data.tags?.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Collect all tags
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  if (post.data.tags) {
    post.data.tags.forEach((t) => {
      tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
    });
  }
});

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) =>
  a[0].localeCompare(b[0])
);
---

<Layout>
  <section>
    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Tags</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="/blog"
          class="text-lg text-slate-11 hover:text-slate-12 hover:underline transition-colors"
        >
          #all
        </a>
        {
          sortedTags.map(([t]) => (
            <a
              href={`/blog/tag/${t}`}
              class:list={[
                "text-lg hover:underline transition-colors",
                tag === t ? "text-cyan-11" : "text-slate-11 hover:text-slate-12"
              ]}
            >
              #{t}
            </a>
          ))
        }
      </div>
    </div>

    <ul class="grid grid-cols-1 gap-12">
      {
        filteredPosts.map((post) => (
          <li>
            <h2 class="text-4xl font-bold mb-2">
              <a href={`/blog/${post.slug}/`} class="hover:underline">
                {post.data.title}
              </a>
            </h2>
            <div class="flex items-center gap-4 mb-3 text-sm text-cyan-11">
              <FormattedDate date={post.data.pubDate} />
              <span>•</span>
              <ReadingTime content={post.body} />
              {post.data.tags && post.data.tags.length > 0 && (
                <>
                  <span>•</span>
                  <div class="flex gap-2">
                    {post.data.tags.map((postTag) => (
                      <a href={`/blog/tag/${postTag}`} class="text-cyan-11 hover:text-cyan-12">
                        #{postTag}
                      </a>
                    ))}
                  </div>
                </>
              )}
            </div>
            <p class="text-slate-11 leading-relaxed">{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
