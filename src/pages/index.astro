---
import Layout from "../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import ReadingTime from "../components/ReadingTime.astro";
import { SOCIAL_LINKS } from "../consts";
import { Typescript, Python, Openjdk, Kotlin, Go, React, Solid, Astro as AstroIcon, Tailwindcss, Nextdotjs, Nodedotjs, Express, Postgresql, Mongodb, Git, Docker, Linux } from "simple-icons-astro";

// Get latest 3 blog posts (newest first)
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 3);

// Get featured projects (if projects collection exists)
let featuredProjects: CollectionEntry<"projects">[] = [];
try {
  const allProjects = await getCollection("projects");
  featuredProjects = allProjects
    .filter((p) => p.data.featured)
    .slice(0, 3)
    .sort((a, b) => {
      const dateA = a.data.date?.valueOf() || 0;
      const dateB = b.data.date?.valueOf() || 0;
      return dateB - dateA;
    });
} catch {
  // Projects collection doesn't exist yet, that's okay
}
---

<Layout>
  <!-- Hero Section -->
  <section class="pb-8">
    <h1 class="text-4xl md:text-5xl font-bold pb-4 text-cyan-12">
      Hi, I'm Anindito Bhagawanta
    </h1>
    <p class="text-xl md:text-2xl font-semibold pb-2 text-cyan-11">
      You can call me Bhaga.
    </p>
    <p class="text-lg">
      I'm a software engineer from Indonesia, building full-stack applications
      and exploring the intersection of technology and creativity. When I'm not
      coding, you'll find me playing video games, working on side projects, or
      tinkering with random stuff.
    </p>
  </section>

  <!-- Skills & Technologies Section -->
  <section class="pb-8">
    <h2 class="text-2xl font-bold pb-4">Skills & Technologies</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h3 class="text-lg font-semibold pb-2 text-cyan-11">Languages</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Typescript class="w-4 h-4" />
            TypeScript
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Python class="w-4 h-4" />
            Python
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Openjdk class="w-4 h-4" />
            Java
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Kotlin class="w-4 h-4" />
            Kotlin
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Go class="w-4 h-4" />
            Go
          </span>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold pb-2 text-cyan-11">Frontend</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <React class="w-4 h-4" />
            React
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Solid class="w-4 h-4" />
            Solid
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <AstroIcon class="w-4 h-4" />
            Astro
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Tailwindcss class="w-4 h-4" />
            Tailwind CSS
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Nextdotjs class="w-4 h-4" />
            Next.js
          </span>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold pb-2 text-cyan-11">Backend</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Nodedotjs class="w-4 h-4" />
            Node.js
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Postgresql class="w-4 h-4" />
            PostgreSQL
          </span>
        </div>
      </div>

      <div>
        <h3 class="text-lg font-semibold pb-2 text-cyan-11">Tools</h3>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Git class="w-4 h-4" />
            Git
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Docker class="w-4 h-4" />
            Docker
          </span>
          <span class="px-3 py-1 bg-slate-3 text-slate-11 rounded-md text-sm flex items-center gap-2">
            <Linux class="w-4 h-4" />
            Linux
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  {
    featuredProjects.length > 0 && (
      <section class="pb-8">
        <div class="flex items-center justify-between pb-4">
          <h2 class="text-2xl font-bold">Featured Projects</h2>
          <a
            href="/projects"
            class="text-cyan-11 hover:text-cyan-12 underline text-sm"
          >
            View all →
          </a>
        </div>
        <ul class="grid grid-cols-1 gap-4">
          {featuredProjects.map((project) => (
            <li class="border-l-2 border-cyan-6 hover:border-cyan-8 transition-colors">
              <div class="p-4 hover:bg-slate-3 transition-colors">
                <div class="flex items-start justify-between pb-2">
                  <div class="flex-1">
                    <h3 class="text-xl font-bold pb-1">{project.data.title}</h3>
                    <p class="text-slate-11 pb-2">{project.data.description}</p>
                    {project.data.tech && project.data.tech.length > 0 && (
                      <div class="flex flex-wrap gap-2 pt-2">
                        {project.data.tech.map((tech: string) => (
                          <span class="px-2 py-0.5 bg-slate-4 text-slate-10 rounded text-xs">
                            {tech}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="flex gap-2 ml-4">
                    {project.data.url && (
                      <a
                        href={project.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-cyan-11 hover:text-cyan-12 underline text-sm"
                        aria-label={`Visit ${project.data.title}`}
                      >
                        Live
                      </a>
                    )}
                    {project.data.github && (
                      <a
                        href={project.data.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-cyan-11 hover:text-cyan-12 underline text-sm"
                        aria-label={`View ${project.data.title} on GitHub`}
                      >
                        Code
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- Latest Blog Posts Section -->
