    latestPosts.length > 0 && (
      <section class="pb-8">
        <div class="flex items-center justify-between pb-4">
          <h2 class="text-2xl font-bold">Latest Posts</h2>
          <a
            href="/blog"
            class="text-cyan-11 hover:text-cyan-12 underline text-sm"
          >
            View all →
          </a>
        </div>
        <ul class="grid grid-cols-1 gap-12">
          {latestPosts.map((post) => (
            <li>
              <h3 class="text-4xl font-bold mb-2">
                <a href={`/blog/${post.slug}/`} class="hover:underline">
                  {post.data.title}
                </a>
              </h3>
              <div class="flex items-center gap-4 mb-3 text-sm text-cyan-11">
                <FormattedDate date={post.data.pubDate} />
                <span>•</span>
                <ReadingTime content={post.body} />
                {post.data.tags && post.data.tags.length > 0 && (
                  <>
                    <span>•</span>
                    <div class="flex gap-2">
                      {post.data.tags.map((tag) => (
                        <a href={`/blog/tag/${tag}`} class="text-cyan-11 hover:text-cyan-12 transition-colors">
                          #{tag}
                        </a>
                      ))}
                    </div>
                  </>
                )}
              </div>
              {post.data.description && (
                <p class="text-slate-11 leading-relaxed">{post.data.description}</p>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  } -->

  <!-- Social Links Section -->
  <section class="pb-8">
    <h2 class="text-2xl font-bold pb-4">Connect</h2>
    <nav>
      <ul class="flex flex-wrap gap-4">
        {
          SOCIAL_LINKS.github && (
            <li>
              <a
                href={SOCIAL_LINKS.github}
                target="_blank"
                rel="noopener noreferrer"
                class="text-cyan-11 hover:text-cyan-12 underline"
              >
                GitHub
              </a>
            </li>
          )
        }
        {
          SOCIAL_LINKS.twitter && (
            <li>
              <a
                href={SOCIAL_LINKS.twitter}
                target="_blank"
                rel="noopener noreferrer"
                class="text-cyan-11 hover:text-cyan-12 underline"
              >
                Twitter
              </a>
            </li>
          )
        }
        {
          SOCIAL_LINKS.linkedin && (
            <li>
              <a
                href={SOCIAL_LINKS.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-cyan-11 hover:text-cyan-12 underline"
              >
                LinkedIn
              </a>
            </li>
          )
        }
        {
          SOCIAL_LINKS.email && (
            <li>
              <a
                href={SOCIAL_LINKS.email}
                class="text-cyan-11 hover:text-cyan-12 underline"
              >
                Email
              </a>
            </li>
          )
        }
      </ul>
    </nav>
  </section>
</Layout>
